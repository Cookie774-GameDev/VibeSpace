{
  "name": "jarvis",
  "version": "0.1.0",
  "private": true,
  "description": "Jarvis - the AI workspace where every model, agent, voice, and task lives under one persistent memory and one always-available assistant.",
  "license": "Apache-2.0",
  "workspaces": [
    "app"
  ],
  "scripts": {
    "dev": "npm --prefix app run dev",
    "build": "npm --prefix app run build",
    "preview": "npm --prefix app run preview",
    "tauri:dev": "npm --prefix app run tauri:dev",
    "tauri:build": "npm --prefix app run tauri:build",
    "typecheck": "npm --prefix app run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css}\""
  },
  "devDependencies": {
    "prettier": "^3.3.3"
  },
  "engines": {
    "node": ">=20"
  }
}
