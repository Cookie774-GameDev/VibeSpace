{
  "name": "jarvis",
  "version": "0.1.45",
  "private": true,
  "description": "VibeSpace — the AI workspace where every model, agent, voice, and task lives under one roof. Jarvis voice and calling built in.",
  "license": "Apache-2.0",
  "workspaces": [
    "app"
  ],
  "scripts": {
    "dev": "npm --prefix app run jarvis",
    "jarvis": "npm --prefix app run jarvis",
    "build": "npm --prefix app run build",
    "preview": "npm --prefix app run preview",
    "tauri:dev": "npm --prefix app run tauri:dev",
    "tauri:build": "npm --prefix app run tauri:build",
    "typecheck": "npm --prefix app run typecheck",
    "test:release-manifest": "node --test scripts/build-updater-manifest.test.mjs",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "release:windows": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/release-windows.ps1",
    "release:stage": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/release-windows.ps1 -SkipBuild",
    "release:rollback": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/rollback-update.ps1",
    "release:install": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"npm run release:windows; if ($LASTEXITCODE -eq 0) { $env:JARVIS_LOCAL=\\\"1\\\"; $env:JARVIS_SILENT=\\\"1\\\"; $env:JARVIS_FORMAT=\\\"nsis\\\"; powershell -NoProfile -ExecutionPolicy Bypass -File install/install.ps1 }\""
  },
  "devDependencies": {
    "prettier": "^3.3.3"
  },
  "engines": {
    "node": ">=20"
  }
}
