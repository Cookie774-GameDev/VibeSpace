# Jarvis - Environment variables (example)
#
# Copy this file to .env.local (in app/ directory) and fill in your real values.
# .env.local is gitignored and will never be committed.
#
# All Vite client-exposed vars must be prefixed VITE_

# --- Supabase (cloud sync + auth) ---
# Get from https://supabase.com -> Project Settings -> API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# --- AI Providers (BYOK) ---
# Optional - users can also enter these in the Settings UI
VITE_ANTHROPIC_API_KEY=
VITE_OPENAI_API_KEY=
VITE_GOOGLE_API_KEY=

# --- Telemetry ---
# Opt-in usage analytics (PostHog). Leave blank to disable.
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://app.posthog.com

# --- Feature flags ---
VITE_ENABLE_VOICE=true
VITE_ENABLE_COUNCIL=true
VITE_ENABLE_CLOUD_SYNC=false

# --- Build ---
VITE_APP_VERSION=0.1.0
