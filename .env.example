# VibeSpace - Environment variables (example)
#
# Copy this file to .env.local (in app/ directory) and fill in your real values.
# .env.local is gitignored and will never be committed.
#
# All Vite client-exposed vars must be prefixed VITE_

# --- VibeSpace Cloud backend (maintainer/release builds) ---
# Official VibeSpace installers include the app backend config at build time.
# Copy to app/.env.local and fill in your Supabase publishable key.
# Replace <your-project-ref> with your Supabase project ref (Dashboard → Settings → General).
VITE_SUPABASE_URL=https://<your-project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=your-publishable-anon-key

# --- AI Providers (BYOK) ---
# Optional - users can also enter these in the Settings UI
VITE_ANTHROPIC_API_KEY=
VITE_OPENAI_API_KEY=
VITE_GOOGLE_API_KEY=

# --- Stripe checkout (one URL per paid tier) ---
# Per-tier checkout links from the Stripe dashboard
# (Products → Payment links). When set, the Plans card flips
# the matching tier's "Available soon" badge to a real
# "Upgrade $N" button. Leave blank to keep the disabled state.
VITE_STRIPE_CHECKOUT_STARTER=
VITE_STRIPE_CHECKOUT_PRO=
VITE_STRIPE_CHECKOUT_ULTRA=
# Legacy single-URL fallback used by the older HostedJarvis card.
# Wired so existing deployments keep working with one env var.
VITE_STRIPE_CHECKOUT_URL=

# --- Jarvis Call / phone-jarvis bridge ---
# Public HTTPS origin for the deployed phone-jarvis cloud service.
# Example: https://phone-jarvis.example.com
VITE_PHONE_JARVIS_CLOUD_URL=

# --- Admin entitlement builds ---
# Use one of these for local owner/admin builds. Admin users resolve to
# Ultra access and can use Jarvis Call even before Stripe subscription
# sync is configured. Do not use this as a server-side auth boundary.
VITE_JARVIS_ADMIN=false
VITE_JARVIS_LOCAL_ADMIN=false
VITE_JARVIS_ADMIN_EMAILS=
VITE_JARVIS_ADMIN_LOCAL_IDS=

# --- Telemetry ---
# Opt-in usage analytics (PostHog). Leave blank to disable.
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://app.posthog.com

# --- Feature flags ---
VITE_ENABLE_VOICE=true
VITE_ENABLE_COUNCIL=true
VITE_ENABLE_CLOUD_SYNC=true

# --- Build ---
VITE_APP_VERSION=0.1.0

# =============================================================================
# Server-side secrets (NOT prefixed VITE_ — never shipped to the client).
# Set these on the Supabase project via `supabase secrets set` so the
# stripe-webhook edge function can read them. They are listed here as
# documentation only; do NOT commit real values.
# =============================================================================

# Stripe — server only
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Stripe Price IDs that map to tiers in profiles.tier
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ULTRA=

# Supabase service role key — used by the edge function to update
# profiles.tier without RLS impersonation. Keep this OFF the client.
SUPABASE_SERVICE_ROLE_KEY=

# --- Voice / Calling / Messaging server secrets (Supabase secrets) ---
# Set via `npx supabase secrets set NAME="value"`. Never commit real values.
# These power the metered cloud TTS, message, and calling Edge Functions.
#
# Price ID aliases (the functions accept either STRIPE_*_PRICE_ID or the
# STRIPE_PRICE_* names above):
STRIPE_STARTER_PRICE_ID=
STRIPE_PRO_PRICE_ID=
STRIPE_ULTRA_PRICE_ID=
#
# Cloud TTS + message AI providers (company-paid; server only):
OPENAI_API_KEY=
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=
#
# Twilio (calling + SMS; server only — the desktop app NEVER holds these):
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_MESSAGING_SERVICE_SID=
#
# App base URL used for Stripe redirects + Twilio webhook URLs:
APP_BASE_URL=
#
# Kokoro local model manifest (public JSON; no secret):
MODEL_MANIFEST_URL=
GITHUB_MODEL_RELEASE_URL=
