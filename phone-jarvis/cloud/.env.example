# Provider keys — fill these in for local dev. Production uses Fly secrets.

# Supabase (operator-side; baked into Jarvis app build, but cloud also reads these)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<supabase-service-role-key>

# Twilio (Path A)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+15551234567

# LiveKit (Path C — get from livekit.io free tier or self-host)
LIVEKIT_API_KEY=APIxxx
LIVEKIT_API_SECRET=secret_xxx
LIVEKIT_URL=wss://your-project.livekit.cloud

# Premium providers (Path A default stack)
DEEPGRAM_API_KEY=...
ANTHROPIC_API_KEY=<anthropic-api-key>
CARTESIA_API_KEY=...

# Free providers (Path C default stack — also fallback for Path A if user BYOK is missing)
GROQ_API_KEY=<groq-api-key>

# Bridge auth — generate via: python -c "import secrets; print(secrets.token_hex(32))"
BRIDGE_TOKEN_PEPPER=replace_me_with_random_64_char_hex

# Audit log retention (days)
AUDIT_RETENTION_DAYS=30

# Cost cap per call (USD; AI hangs up if exceeded)
COST_CAP_PER_CALL=5.00

# Idle hangup (seconds of user silence before "you still there?")
IDLE_HANGUP_SECONDS=120
