{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability for the Jarvis main window. Grants the core IPC surface plus notification/dialog/os defaults and shell:open for external URLs. The http plugin scope explicitly allows the Ollama daemon and the major BYOK provider hosts so the native HTTP client can serve as a CORS-free fallback when the WebView blocks direct fetches in packaged builds.",
  "windows": ["main", "dictation"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:window:default",
    "core:webview:default",
    "core:app:default",
    "core:path:default",
    "notification:default",
    "dialog:default",
    "shell:allow-open",
    "os:default",
    "process:default",
    "updater:default",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "http://localhost:11434/*" },
        { "url": "http://127.0.0.1:11434/*" },
        { "url": "https://api.openai.com/*" },
        { "url": "https://api.anthropic.com/*" },
        { "url": "https://generativelanguage.googleapis.com/*" },
        { "url": "https://api.groq.com/*" },
        { "url": "https://api.github.com/*" },
        { "url": "https://api.figma.com/*" },
        { "url": "https://*.supabase.co/*" },
        { "url": "https://*.myshopify.com/*" },
        { "url": "https://slack.com/*" }
      ]
    }
  ]
}
