{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability for the Jarvis main window. Grants the core IPC surface plus notification/dialog/os defaults and shell:open for external URLs.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:window:default",
    "core:webview:default",
    "core:app:default",
    "core:path:default",
    "notification:default",
    "dialog:default",
    "shell:allow-open",
    "os:default"
  ]
}
